meta {
  name: accept-invite-preview-invalid-token
  type: http
  seq: 9
}

get {
  url: http://localhost:8000/api/v1/auth/accept-invite?token=invalid.token.here
  body: none
  auth: none
}

params:query {
  token: invalid.token.here
}

assert {
  res.status: eq 400
  res.body.detail: contains "Token invalid or expired"
}
