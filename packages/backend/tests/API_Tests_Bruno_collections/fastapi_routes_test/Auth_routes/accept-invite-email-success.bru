meta {
  name: accept-invite-email-success
  type: http
  seq: 12
}

post {
  url: http://localhost:8000/api/v1/auth/accept-invite
  body: json
  auth: none
}

body:json {
  {
    "token": "{{invite_token}}",
    "full_name": "user_cctv",
    "password": "user@123"
  }
}

assert {
  res.status: eq 409
  res.body.detail: contains "Email already registered"
}
