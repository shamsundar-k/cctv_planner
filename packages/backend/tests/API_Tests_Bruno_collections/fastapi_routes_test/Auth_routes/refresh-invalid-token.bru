meta {
  name: refresh-invalid-token
  type: http
  seq: 5
}

post {
  url: http://localhost:8000/api/v1/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refresh_token": "invalid.refresh.token.here"
  }
}

assert {
  res.status: eq 401
  res.body.detail: contains "Invalid or expired refresh token"
}
