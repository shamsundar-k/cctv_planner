meta {
  name: accept-invite-preview
  type: http
  seq: 8
}

get {
  url: http://localhost:8000/api/v1/auth/accept-invite?token={{invite_token}}
  body: none
  auth: none
}

params:query {
  token: {{invite_token}}
}

assert {
  res.status: eq 200
  res.body.email: isString
  res.body.expires_at: isString
}

script:post-response {
  console.log("Invite token preview retrieved successfully");
  console.log("Email:", res.body.email);
}
