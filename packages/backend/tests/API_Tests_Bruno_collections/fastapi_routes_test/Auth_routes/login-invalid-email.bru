meta {
  name: login-invalid-email
  type: http
  seq: 2
}

post {
  url: http://localhost:8000/api/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "nonexistent@example.com",
    "password": "AnyPassword123"
  }
}

assert {
  res.status: eq 401
  res.body.detail: contains "Invalid email or password"
}
