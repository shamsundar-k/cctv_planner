meta {
  name: accept-invite-invalid-token
  type: http
  seq: 12
}

post {
  url: http://localhost:8000/api/v1/auth/accept-invite
  body: json
  auth: none
}

body:json {
  {
    "token": "invalid.invite.token",
    "full_name": "Test User",
    "password": "TestPassword123"
  }
}

assert {
  res.status: eq 400
  res.body.detail: contains "Token invalid or expired"
}
