meta {
  name: login-invalid-password
  type: http
  seq: 3
}

post {
  url: http://localhost:8000/api/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "testuser@example.com",
    "password": "WrongPassword123"
  }
}

assert {
  res.status: eq 401
  res.body.detail: contains "Invalid email or password"
}
