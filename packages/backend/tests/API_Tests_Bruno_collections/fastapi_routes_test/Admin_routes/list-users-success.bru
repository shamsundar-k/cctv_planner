meta {
  name: list-users-success
  type: http
  seq: 6
}

get {
  url: http://localhost:8000/api/v1/admin/users
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

assert {
  res.status: eq 200
  res.body: isArray
}

script:post-response {
  console.log("User list retrieved successfully, count:", res.body.length);
}
