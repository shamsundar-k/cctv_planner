meta {
  name: list-users-non-admin
  type: http
  seq: 8
}

get {
  url: http://localhost:8000/api/v1/admin/users
  auth: bearer
}

auth:bearer {
  token: {{non_admin_access_token}}
}

assert {
  res.status: eq 403
  res.body.detail: isString
}

script:post-response {
  console.log("Non-admin user list request correctly rejected with 403");
}
