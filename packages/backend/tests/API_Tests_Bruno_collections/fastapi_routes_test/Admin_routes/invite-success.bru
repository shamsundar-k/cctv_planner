meta {
  name: invite-success
  type: http
  seq: 1
}

post {
  url: http://localhost:8000/api/v1/admin/invite
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "email": "user@gmail.com"
  }
}

assert {
  res.status: eq 201
  res.body.invite_url: isString
  res.body.expires_at: isString
}

script:post-response {
  // Save invite_url for reference in subsequent tests
  bru.setEnvVar("invite_url", res.body.invite_url);
  console.log("Invite created successfully:", res.body.invite_url);
}
