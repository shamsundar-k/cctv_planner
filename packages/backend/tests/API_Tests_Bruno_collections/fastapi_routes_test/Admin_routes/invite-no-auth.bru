meta {
  name: invite-no-auth
  type: http
  seq: 3
}

post {
  url: http://localhost:8000/api/v1/admin/invite
  body: json
  auth: none
}

body:json {
  {
    "email": "newuser@example.com"
  }
}

assert {
  res.status: eq 403
  res.body.detail: contains Not authenticated
}

script:post-response {
  console.log("Unauthenticated invite request correctly rejected with 403");
}
