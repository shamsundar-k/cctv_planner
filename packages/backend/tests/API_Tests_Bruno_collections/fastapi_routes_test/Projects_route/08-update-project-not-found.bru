meta {
  name: update-project-not-found
  type: http
  seq: 8
}

put {
  url: http://localhost:8000/api/v1/projects/000000000000000000000001
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "Ghost Project"
  }
}

assert {
  res.status: eq 404
  res.body.detail: eq "Project not found"
}
