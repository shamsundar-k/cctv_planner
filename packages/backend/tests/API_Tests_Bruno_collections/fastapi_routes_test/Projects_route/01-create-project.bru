meta {
  name: create-project
  type: http
  seq: 1
}

post {
  url: http://localhost:8000/api/v1/projects
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "name": "Bruno-Test-Project",
    "description": "A project created by Bruno API tests",
    "center_lat": 51.5074,
    "center_lng": -0.1278,
    "default_zoom": 15
  }
}

assert {
  res.status: eq 201
  res.body.id: isString
  res.body.name: eq "Bruno-Test-Project"
  res.body.description: eq "A project created by Bruno API tests"
  res.body.center_lat: eq 51.5074
  res.body.center_lng: eq -0.1278
  res.body.default_zoom: eq 15
  res.body.camera_count: eq 0
  res.body.zone_count: eq 0
  res.body.owner_id: isString
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("project_id", res.body.id);
  }
}
