meta {
  name: get-project-success
  type: http
  seq: 5
}

get {
  url: http://localhost:8000/api/v1/projects/{{project_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

assert {
  res.status: eq 200
  res.body.id: eq {{project_id}}
  res.body.name: eq "Bruno-Test-Project"
  res.body.cameras: isArray
  res.body.zones: isArray
}
