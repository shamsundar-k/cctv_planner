# ── Backend ──────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cctv_planner?retryWrites=true&w=majority
REDIS_URL=redis://:password@host:port

JWT_SECRET=replace-with-a-random-64-char-string
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
INVITE_TOKEN_TTL_HOURS=72

FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=changeme

# ── Frontend (Vite build-time) ────────────────────────
VITE_API_BASE_URL=/api/v1
VITE_WS_BASE_URL=/ws
VITE_STADIA_MAPS_API_KEY=replace-with-your-stadia-key
