sequenceDiagram
    autonumber
    actor User
    participant LoginPage
    participant AxiosClient as Axios Client<br/>(interceptors.ts)
    participant AuthStore as Zustand AuthStore<br/>(authSlice.ts)
    participant LocalStorage
    participant API as FastAPI Backend

    %% ── Login ─────────────────────────────────────────────
    User->>LoginPage: submit email + password
    LoginPage->>AxiosClient: POST /auth/login
    AxiosClient->>API: POST /api/v1/auth/login
    API-->>AxiosClient: { access_token, refresh_token }
    AxiosClient-->>LoginPage: response
    LoginPage->>AuthStore: setAuth(user, accessToken, refreshToken)
    AuthStore->>LocalStorage: persist { user, accessToken, refreshToken }
    LoginPage-->>User: redirect → /

    %% ── Authenticated Request ─────────────────────────────
    Note over AxiosClient,API: Every subsequent request
    AxiosClient->>AuthStore: getState().accessToken
    AuthStore-->>AxiosClient: "eyJ..."
    AxiosClient->>API: GET /api/v1/... Authorization: Bearer eyJ...
    API-->>AxiosClient: 200 OK + data

    %% ── Silent Token Refresh (401) ─────────────────────────
    Note over AxiosClient,API: Access token expired
    AxiosClient->>API: GET /api/v1/... Authorization: Bearer <expired>
    API-->>AxiosClient: 401 Unauthorized
    AxiosClient->>AxiosClient: set _retry = true
    AxiosClient->>AuthStore: getState().refreshToken
    AuthStore-->>AxiosClient: "<refresh_token>"
    AxiosClient->>API: POST /api/v1/auth/refresh { refresh_token }
    API-->>AxiosClient: { access_token }
    AxiosClient->>AuthStore: setAccessToken(newAccessToken)
    AuthStore->>LocalStorage: persist updated accessToken
    AxiosClient->>API: retry original GET /api/v1/... (new token)
    API-->>AxiosClient: 200 OK + data

    %% ── Refresh Failure ────────────────────────────────────
    Note over AxiosClient,API: Refresh token also invalid/expired
    AxiosClient->>API: POST /api/v1/auth/refresh { refresh_token }
    API-->>AxiosClient: 401 Unauthorized
    AxiosClient->>AuthStore: clearAuth()
    AuthStore->>LocalStorage: clear cctv-auth
    AxiosClient-->>User: redirect → /login
