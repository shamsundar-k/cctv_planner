flowchart TB
    subgraph Client["Browser (React SPA)"]
        UI[Map Canvas · Leaflet.js]
        ZS[Zustand Store]
        RQ[TanStack Query v5]
        WS_C[WebSocket Client]
        Axios[Axios HTTP Client]
    end

    subgraph Nginx["Nginx (port 80 / 443)"]
        Static[Serve /dist<br/>static build]
        ProxyAPI[Proxy /api/*<br/>→ backend:8000]
        ProxyWS[Upgrade /ws/*<br/>→ backend:8000]
    end

    subgraph Backend["FastAPI (Python 3.12 · port 8000)"]
        subgraph Routers["REST Routers"]
            AuthR[Auth + Invite Router]
            AdminR[Admin Router]
            ProjectR[Projects Router]
            CameraR[Cameras Router]
            ZoneR[Zones Router]
            CoverageR[Coverage Router]
            ExportR[Export Router]
        end

        subgraph Services["Internal Services"]
            GIS[GIS Service<br/>Shapely + pyproj]
            WSMgr[WebSocket Manager]
            ReportSvc[Report Service<br/>WeasyPrint + Jinja2]
            KMLSvc[KML Service<br/>simplekml]
        end

        subgraph Core["Core"]
            Config[Config<br/>pydantic-settings]
            Security[Security<br/>JWT · bcrypt]
            Deps[Dependencies<br/>get_current_user]
        end
    end

    subgraph Data["Data Layer"]
        Mongo[(MongoDB 7<br/>Beanie ODM)]
        Redis[(Redis 7<br/>Tokens + Presence)]
    end

    Client -->|HTTP REST| Nginx
    WS_C -->|WebSocket| Nginx
    Nginx --> Static
    ProxyAPI --> AuthR & AdminR & ProjectR & CameraR & ZoneR & CoverageR & ExportR
    ProxyWS --> WSMgr

    CameraR -->|FOV compute| GIS
    CoverageR -->|coverage stats| GIS
    ExportR --> ReportSvc & KMLSvc

    AuthR --> Mongo & Redis
    AdminR --> Mongo
    ProjectR --> Mongo
    CameraR --> Mongo
    ZoneR --> Mongo
    GIS --> Mongo
    WSMgr --> Redis
    ReportSvc --> Mongo
    KMLSvc --> Mongo
